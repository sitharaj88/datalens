{
  "name": "datalens-db-viewer",
  "displayName": "DataLens - Database Viewer Pro",
  "description": "All-in-one database client for VS Code — browse schemas, run queries, edit data, visualize charts, and manage 15+ databases including PostgreSQL, MySQL, MongoDB, Redis, SQLite, and more",
  "version": "1.0.0",
  "publisher": "sitharaj",
  "author": {
    "name": "Sitharaj Seenivasan",
    "url": "https://github.com/sitharaj88"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sitharaj88/datalens.git"
  },
  "homepage": "https://github.com/sitharaj88/datalens#readme",
  "bugs": {
    "url": "https://github.com/sitharaj88/datalens/issues"
  },
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other",
    "Visualization",
    "Data Science"
  ],
  "keywords": [
    "database",
    "sql",
    "sqlite",
    "postgresql",
    "mysql",
    "mariadb",
    "mongodb",
    "redis",
    "neo4j",
    "clickhouse",
    "cassandra",
    "dynamodb",
    "elasticsearch",
    "firestore",
    "oracle",
    "cockroachdb",
    "query",
    "viewer",
    "erd",
    "schema",
    "ssh-tunnel",
    "ai-sql"
  ],
  "icon": "media/logo.png",
  "galleryBanner": {
    "color": "#6366F1",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbViewer",
          "title": "DataLens",
          "icon": "media/icons/database.svg"
        }
      ]
    },
    "views": {
      "dbViewer": [
        {
          "id": "dbViewer.connections",
          "name": "Connections"
        },
        {
          "id": "dbViewer.schemaExplorer",
          "name": "Schema Explorer"
        },
        {
          "id": "dbViewer.queryLibrary",
          "name": "Saved Queries"
        }
      ]
    },
    "commands": [
      {
        "command": "dbViewer.addConnection",
        "title": "Add Connection",
        "icon": "$(add)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.addConnectionFromURI",
        "title": "Add Connection from URI",
        "icon": "$(link)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.removeConnection",
        "title": "Remove Connection",
        "icon": "$(trash)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.connect",
        "title": "Connect",
        "icon": "$(plug)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.disconnect",
        "title": "Disconnect",
        "icon": "$(debug-disconnect)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.newQuery",
        "title": "New Query",
        "icon": "$(new-file)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.runQuery",
        "title": "Run Query",
        "icon": "$(play)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.viewTableData",
        "title": "View Data",
        "icon": "$(table)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.exportData",
        "title": "Export Data",
        "icon": "$(export)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.discoverConnections",
        "title": "Discover Connections from .env",
        "icon": "$(search)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.createGroup",
        "title": "Create Connection Group",
        "icon": "$(folder-opened)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.renameGroup",
        "title": "Rename Group",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.deleteGroup",
        "title": "Delete Group",
        "icon": "$(trash)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.copyTableName",
        "title": "Copy Table Name",
        "icon": "$(clippy)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.generateSelect",
        "title": "Generate SELECT Query",
        "icon": "$(code)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.generateInsert",
        "title": "Generate INSERT Template",
        "icon": "$(code)",
        "category": "DataLens"
      },
      {
        "command": "dbViewer.globalSearch",
        "title": "Search Across Databases",
        "icon": "$(search)",
        "category": "DataLens"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dbViewer.addConnection",
          "when": "view == dbViewer.connections",
          "group": "navigation"
        },
        {
          "command": "dbViewer.addConnectionFromURI",
          "when": "view == dbViewer.connections",
          "group": "navigation"
        },
        {
          "command": "dbViewer.discoverConnections",
          "when": "view == dbViewer.connections",
          "group": "navigation"
        },
        {
          "command": "dbViewer.createGroup",
          "when": "view == dbViewer.connections",
          "group": "navigation"
        },
        {
          "command": "dbViewer.refresh",
          "when": "view == dbViewer.schemaExplorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "dbViewer.connect",
          "when": "view == dbViewer.connections && viewItem == connection-disconnected",
          "group": "inline"
        },
        {
          "command": "dbViewer.disconnect",
          "when": "view == dbViewer.connections && viewItem == connection-connected",
          "group": "inline"
        },
        {
          "command": "dbViewer.removeConnection",
          "when": "view == dbViewer.connections && viewItem =~ /^connection/",
          "group": "inline"
        },
        {
          "command": "dbViewer.viewTableData",
          "when": "view == dbViewer.schemaExplorer && viewItem == table",
          "group": "inline"
        },
        {
          "command": "dbViewer.newQuery",
          "when": "view == dbViewer.schemaExplorer && viewItem == table"
        },
        {
          "command": "dbViewer.copyTableName",
          "when": "view == dbViewer.schemaExplorer && viewItem == table",
          "group": "1_copy"
        },
        {
          "command": "dbViewer.generateSelect",
          "when": "view == dbViewer.schemaExplorer && viewItem == table",
          "group": "2_generate"
        },
        {
          "command": "dbViewer.generateInsert",
          "when": "view == dbViewer.schemaExplorer && viewItem == table",
          "group": "2_generate"
        },
        {
          "command": "dbViewer.exportData",
          "when": "view == dbViewer.schemaExplorer && viewItem == table",
          "group": "3_export"
        },
        {
          "command": "dbViewer.renameGroup",
          "when": "view == dbViewer.connections && viewItem == group"
        },
        {
          "command": "dbViewer.deleteGroup",
          "when": "view == dbViewer.connections && viewItem == group"
        }
      ]
    },
    "configuration": {
      "title": "DataLens",
      "properties": {
        "dbViewer.maxRows": {
          "type": "number",
          "default": 1000,
          "description": "Maximum number of rows to fetch in queries"
        },
        "dbViewer.autoDiscover": {
          "type": "boolean",
          "default": true,
          "description": "Automatically discover database connections from .env files"
        },
        "dbViewer.queryTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Query timeout in milliseconds"
        },
        "dbViewer.confirmDelete": {
          "type": "boolean",
          "default": true,
          "description": "Show confirmation dialog before deleting rows"
        },
        "dbViewer.ai.provider": {
          "type": "string",
          "enum": [
            "copilot",
            "openai",
            "anthropic",
            "ollama"
          ],
          "enumDescriptions": [
            "Use the GitHub Copilot models already available in VS Code (no API key required; requires GitHub Copilot)",
            "OpenAI API (requires an API key)",
            "Anthropic API (requires an API key)",
            "Local Ollama models (no API key; runs on your machine)"
          ],
          "default": "openai",
          "description": "AI provider for natural language to SQL and the AI agent. 'copilot' reuses your existing GitHub Copilot subscription — no API key needed."
        },
        "dbViewer.ai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for AI provider"
        },
        "dbViewer.ai.model": {
          "type": "string",
          "default": "",
          "description": "Model to use for AI features (e.g., gpt-4, claude-sonnet-4-5-20250929)"
        },
        "dbViewer.ai.agentMaxSteps": {
          "type": "number",
          "default": 8,
          "minimum": 1,
          "maximum": 25,
          "description": "Maximum number of steps the AI agent may take to accomplish a goal."
        },
        "dbViewer.ai.agentAllowWrites": {
          "type": "boolean",
          "default": false,
          "description": "Allow the AI agent to run data-modifying statements (INSERT/UPDATE/DELETE/DDL). When off, the agent is restricted to read-only queries. Even when on, destructive operations still require confirmation."
        },
        "dbViewer.dataMasking.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable data masking for sensitive columns"
        },
        "dbViewer.dataMasking.patterns": {
          "type": "array",
          "default": [
            "email",
            "password",
            "ssn",
            "credit_card",
            "phone"
          ],
          "description": "Column name patterns to mask"
        },
        "dbViewer.schemaCacheTTL": {
          "type": "number",
          "default": 60000,
          "description": "Schema cache time-to-live in milliseconds"
        },
        "dbViewer.security.storePasswords": {
          "type": "boolean",
          "default": true,
          "description": "Store connection passwords in VS Code SecretStorage. When disabled, passwords are never persisted and you are prompted for them each time you connect. Note: SecretStorage is not isolated between extensions — see SECURITY.md."
        },
        "dbViewer.guardDestructiveQueries": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before running destructive statements (DROP, TRUNCATE, and DELETE/UPDATE without a WHERE clause). Production connections and irreversible operations require a typed confirmation."
        }
      }
    },
    "chatParticipants": [
      {
        "id": "datalens.chat",
        "name": "datalens",
        "fullName": "DataLens",
        "description": "Ask questions about your connected database in natural language",
        "isSticky": true
      }
    ],
    "languageModelTools": [
      {
        "name": "datalens_run_sql",
        "displayName": "Run SQL (DataLens)",
        "modelDescription": "Execute a single read-only SQL query (SELECT/SHOW/EXPLAIN) against the user's active DataLens database connection and return the resulting rows. Write and DDL statements are rejected.",
        "toolReferenceName": "runSql",
        "canBeReferencedInPrompt": true,
        "icon": "$(database)",
        "tags": [
          "datalens",
          "database",
          "sql"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {
            "sql": {
              "type": "string",
              "description": "A single read-only SQL statement to execute against the active connection."
            }
          },
          "required": [
            "sql"
          ]
        }
      },
      {
        "name": "datalens_get_schema",
        "displayName": "Get database schema (DataLens)",
        "modelDescription": "Return the tables, columns and views of the user's active DataLens database connection, so SQL can be written against the real schema.",
        "toolReferenceName": "dbSchema",
        "canBeReferencedInPrompt": true,
        "icon": "$(table)",
        "tags": [
          "datalens",
          "database",
          "schema"
        ],
        "inputSchema": {
          "type": "object",
          "properties": {}
        }
      }
    ],
    "walkthroughs": [
      {
        "id": "datalens.getStarted",
        "title": "Get Started with DataLens",
        "description": "Connect a database, run your first query, edit data safely, and try AI-powered SQL — all without leaving VS Code.",
        "steps": [
          {
            "id": "datalens.addConnection",
            "title": "Add a database connection",
            "description": "DataLens supports 15+ databases. Add one via a form, a connection URI, or auto-discovery from your workspace .env files.\n[Add Connection](command:dbViewer.addConnection)",
            "media": {
              "markdown": "media/walkthrough/add-connection.md"
            },
            "completionEvents": [
              "onCommand:dbViewer.addConnection",
              "onCommand:dbViewer.addConnectionFromURI"
            ]
          },
          {
            "id": "datalens.runQuery",
            "title": "Run your first query",
            "description": "Open a query tab and run SQL with Ctrl/Cmd+Enter. The Monaco editor gives you schema-aware, alias-resolving autocomplete.\n[New Query](command:dbViewer.newQuery)",
            "media": {
              "markdown": "media/walkthrough/run-query.md"
            },
            "completionEvents": [
              "onCommand:dbViewer.newQuery"
            ]
          },
          {
            "id": "datalens.editSafely",
            "title": "Edit data with guardrails",
            "description": "Edit rows inline in the results grid. Destructive statements (DROP, TRUNCATE, DELETE/UPDATE without WHERE) ask for confirmation — and production connections require a typed confirmation.",
            "media": {
              "markdown": "media/walkthrough/edit-safely.md"
            }
          },
          {
            "id": "datalens.aiSql",
            "title": "Generate SQL with AI",
            "description": "Describe what you want in plain English and let DataLens write the SQL. Works with OpenAI, Anthropic, or a local Ollama model.\n[Open Settings](command:workbench.action.openSettings?%22dbViewer.ai%22)",
            "media": {
              "markdown": "media/walkthrough/ai-sql.md"
            }
          },
          {
            "id": "datalens.security",
            "title": "Know how your credentials are stored",
            "description": "Credentials are kept in VS Code SecretStorage, never in plaintext. Learn the one important limitation and how to lock down production connections.",
            "media": {
              "markdown": "media/walkthrough/security.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "npm run build:extension && npm run build:webview",
    "build:extension": "esbuild src/extension/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:ssh2 --external:@clickhouse/client --external:neo4j-driver --external:@aws-sdk/client-dynamodb --external:@aws-sdk/lib-dynamodb --external:pg --external:mysql2 --external:mongodb --external:ioredis --external:cassandra-driver --external:oracledb --external:tedious --external:better-sqlite3 --external:@elastic/elasticsearch --external:firebase-admin --format=cjs --platform=node --minify && node scripts/copy-wasm.mjs",
    "build:webview": "cd src/webview && npm run build",
    "watch": "concurrently \"npm run watch:extension\" \"npm run watch:webview\"",
    "watch:extension": "node scripts/copy-wasm.mjs && esbuild src/extension/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:ssh2 --external:@clickhouse/client --external:neo4j-driver --external:@aws-sdk/client-dynamodb --external:@aws-sdk/lib-dynamodb --external:pg --external:mysql2 --external:mongodb --external:ioredis --external:cassandra-driver --external:oracledb --external:tedious --external:better-sqlite3 --external:@elastic/elasticsearch --external:firebase-admin --format=cjs --platform=node --watch --sourcemap",
    "watch:webview": "cd src/webview && npm run dev",
    "lint": "eslint src --ext ts,tsx",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "test": "vitest",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ssh2": "^1.15.0",
    "@types/vscode": "^1.125.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.32.0",
    "concurrently": "^8.2.2",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/lib-dynamodb": "^3.500.0",
    "@clickhouse/client": "^0.2.0",
    "@elastic/elasticsearch": "^8.12.0",
    "cassandra-driver": "^4.7.0",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.0",
    "firebase-admin": "^12.0.0",
    "ioredis": "^5.3.0",
    "mongodb": "^6.3.0",
    "mysql2": "^3.9.0",
    "neo4j-driver": "^5.17.0",
    "oracledb": "^6.3.0",
    "pg": "^8.11.3",
    "sql.js": "^1.13.0",
    "ssh2": "^1.15.0",
    "tedious": "^18.0.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  }
}
